<%- layout("/layouts/boilerplate") %>
    <div class="row mt-2">
        <div class="col-8 offset-2">
            <h2>Edit Your Listing</h2>
            <form method="post" action="/listings/<%= listing._id %>?_method=PUT">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" value="<%= listing.title %>" placeholder="Enter Titile" id="" class="form-control">
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" id="" class="form-control"><%= listing.description %></textarea>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image</label>
                    <input type="text" value="<%= listing.image %>" id="" placeholder="Enter Image URL/Link" class="form-control">
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input type="number" value="<%= listing.price %>" id="" placeholder="Enter Price" class="form-control">
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" value="<%= listing.location %>" id="" placeholder="Enter Location" class="form-control">
                    </div>
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" value="<%= listing.country %>" id="" placeholder="Enter Country" class="form-control">
                </div>
                <button class="btn btn-dark edit-btn mt-3">EDIT</button>    
            </form>
        </div>
    </div>
