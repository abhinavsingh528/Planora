<%- layout("/layouts/boilerplate") %>
    <div class="row">
        <div class="col-8 offset-2">
            <h2>Create Listing:</h2>
            <form method="post" action="/listings" novalidate class="needs-validation">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" name="listing[title]" placeholder="Add a catchy title" id="" class="form-control" required>    
                    <div class="valid-feedback">Title Looks Great!</div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" placeholder="Enter Description" id="" class="form-control" required></textarea>  
                    <div class="invalid-feedback">Please enter a short description</div>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image</label>
                    <input type="text" name="listing[image]" id="" placeholder="Enter Image URL/Link" class="form-control">
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input  name="listing[price]" id="" placeholder="1200" class="form-control" required>
                        <div class="invalid-feedback">Price should be vaild.</div>    
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" name="listing[country]" id="" placeholder="India" class="form-control" required>        
                        <div class="invalid-feedback">Country name should be vaild.</div>
                    </div>
                </div>
                <div class="mb-3">
                        <label for="location" class="form-label">Location</label>
                        <input type="text" name="listing[location]" id="" placeholder="Lucknow, Uttar Pradesh" class="form-control" required>
                        <div class="invalid-feedback">Location should be vaild.</div>
                    </div>
            <button class="btn btn-dark add-btn">ADD</button>    
        </form>
        </div>
    </div>
